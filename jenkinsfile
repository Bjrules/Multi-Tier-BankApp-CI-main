pipeline{
    agent any

    tools {
        maven 'maven3'
    }
    // Define environment variables, 
environment {
SCANNER_HOME = tool 'sonar-scanner'
}
parameters{
    string(name: 'DOCKER_TAG', defaultValue:'latest', description: 'Docker tag')
}
    stages{

                // Stage to clean the workspace
        stage('Clean Workspace') {
            steps {
                    cleanWs() // Clean up previous files
                }
        }
        stage('Git Checkout'){
            steps {
                git branch: 'main', credentialsId: 'github-cred', url: 'https://github.com/Bjrules/Multi-Tier-BankApp-CI-main.git'
            }
        }

        stage('compile'){
            steps {
                sh "mvn compile"
            }
        }
        stage('test'){
            steps {
                sh "mvn test -DskipTests=true" // This enable jenkins to skip this testing stage
            }
        }

        stage('File System Scan'){
            steps {
              sh "trivy fs --format table -o fs.html ." // Scan filesystem and save report as HTML
            }
        }
         stage('SonarQube Analysis'){
            steps {
                // kindly remove credentialID as parameter in withSonarQubeEnv
               withSonarQubeEnv('Sonar-Server') {
                    sh ''' $SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=bankapp -Dsonar.projectKey=bankapp \
-Dsonar.java.binaries=target '''
                }
            }
        }

//          stage('Build and Publish to Nexus'){
//             steps {
//                 withMaven(globalMavenSettingsConfig: 'Banjo-maven-Settings', maven: 'maven3', traceability: true) {
//                      sh "mvn deploy"
// }
//             }
//         }

        stage('Docker Build and Tag'){
            steps {
                script{
               withDockerRegistry(credentialsId: 'Docker-Login') {
                sh "docker build -t bjrules/bankapp:${params.DOCKER_TAG} . "
               }
        }
            }
        }

        stage('Docker Image Scan'){
            steps {
              sh "trivy image --format table -o dimage.html bjrules/bankapp:${params.DOCKER_TAG} " // Scan filesystem and save report as HTML
            }
        }
            
        stage('Docker Push'){
            steps {
                script{
               withDockerRegistry(credentialsId: 'Docker-Login') {
                sh "docker push bjrules/bankapp:${params.DOCKER_TAG} ."
               }
        }
            }
        }


    }
}